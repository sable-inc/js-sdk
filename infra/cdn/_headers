# Cloudflare Pages custom headers for sdk.withsable.com
#
# Docs: https://developers.cloudflare.com/pages/configuration/headers/
#
# We serve two files per version pin:
#
#   sable.js         — the 1 KB IIFE loader stub (Stripe.js-style). Tiny,
#                       runs on page load, lazy-imports sable-core.mjs on
#                       the first Sable.start() call.
#   sable-core.mjs   — the full SDK (~150 KB gzipped, livekit inlined).
#                       Loaded on demand via dynamic import from the same
#                       path as the loader.
#
# Both files live under three path conventions:
#
#   /v0.1.4/{sable.js,sable-core.mjs}   — exact-pinned, IMMUTABLE cache.
#                         Safe to cache for a year because publishing a new
#                         version creates a new path, not a new file at the
#                         same path.
#
#   /v1/{sable.js,sable-core.mjs}        — latest 0.x MINOR pin. 1 hour cache
#                         — short enough to propagate a patch release quickly,
#                         long enough to absorb traffic spikes. No `immutable`.
#
#   /latest/{sable.js,sable-core.mjs}    — always newest. 5-minute edge cache.
#                         Strongly discouraged for production (docs warn) but
#                         useful for demos and smoke tests.
#
# CORS is permissive (`*`) because the SDK is explicitly script-tag-friendly:
# customers embed it on any origin and the auth boundary is the publishable
# key's allowed-domains list, not the CDN's CORS headers.

/*
  Access-Control-Allow-Origin: *
  Access-Control-Allow-Methods: GET, HEAD, OPTIONS
  Cross-Origin-Resource-Policy: cross-origin
  X-Content-Type-Options: nosniff
  Referrer-Policy: no-referrer

/v0.*/sable.js
  Cache-Control: public, max-age=31536000, immutable
/v0.*/sable-core.mjs
  Cache-Control: public, max-age=31536000, immutable

/v1/sable.js
  Cache-Control: public, max-age=3600, s-maxage=3600
/v1/sable-core.mjs
  Cache-Control: public, max-age=3600, s-maxage=3600

/latest/sable.js
  Cache-Control: public, max-age=300, s-maxage=300
/latest/sable-core.mjs
  Cache-Control: public, max-age=300, s-maxage=300
